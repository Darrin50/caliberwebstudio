# Resend API Key (get from resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Key (get from platform.openai.com)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firecrawl API Key (get from firecrawl.dev — used for prospect recon scraping)
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Keys (get from dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Stripe Webhook Secret — set this after creating the webhook endpoint in the Stripe dashboard
# Stripe Dashboard → Developers → Webhooks → Add endpoint → https://caliberwebstudio.com/api/webhook/stripe
# → Select event: checkout.session.completed → copy "Signing secret"
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Site URL
NEXT_PUBLIC_SITE_URL=https://caliberwebstudio.com

# ─── Client Portal ───
PORTAL_JWT_SECRET=your-secret-key-min-32-chars
NEXT_PUBLIC_URL=https://caliberwebstudio.com

# ─── Stripe Price IDs ───
STRIPE_PRICE_ID_STARTER_MONTHLY=price_starter_m
STRIPE_PRICE_ID_STARTER_ANNUAL=price_starter_a
STRIPE_PRICE_ID_GROWTH_MONTHLY=price_growth_m
STRIPE_PRICE_ID_GROWTH_ANNUAL=price_growth_a
STRIPE_PRICE_ID_DOMINATION_MONTHLY=price_domination_m
STRIPE_PRICE_ID_DOMINATION_ANNUAL=price_domination_a

# ─── Google Service Account (for portal analytics) ───
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# ─── Per-Client Google Property IDs ───
GA_PROPERTY_DETROIT_CUTS=
GSC_PROPERTY_DETROIT_CUTS=
GBP_ID_DETROIT_CUTS=
STRIPE_CUSTOMER_DETROIT_CUTS=
STRIPE_SUB_DETROIT_CUTS=

