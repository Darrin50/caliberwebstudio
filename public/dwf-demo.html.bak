<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Detroit Waffle Factory — Stacked in Detroit</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      /* Dark mode base - Warmth + Energy hybrid */
      --color-bg-primary: #0A0A0B;
      --color-bg-secondary: #141416;
      --color-bg-tertiary: #1C1C1F;
      --color-text-primary: #F3F4F6;
      --color-text-secondary: #9CA3AF;
      --color-text-tertiary: #6B7280;
      --color-border-default: #27272A;

      /* Brand colors - Detroit Waffle Factory */
      --color-brand-primary: #C41E1E; /* Red from logo */
      --color-brand-secondary: #D4A020; /* Gold/Yellow from logo */
      --color-brand-accent: rgba(196, 30, 30, 0.08);

      /* Semantic */
      --color-success: #059669;

      /* Typography */
      --font-heading: 'Poppins', system-ui, sans-serif;
      --font-body: 'Inter', system-ui, -apple-system, sans-serif;

      /* Type scale */
      --text-xs: 0.75rem;
      --text-sm: 0.875rem;
      --text-base: 1rem;
      --text-lg: 1.125rem;
      --text-xl: 1.25rem;
      --text-2xl: 1.5rem;
      --text-3xl: 1.875rem;
      --text-4xl: 2.25rem;
      --text-5xl: 3rem;
      --text-6xl: 3.75rem;

      --heading-hero: clamp(2.5rem, 5vw, 4.5rem);
      --heading-section: clamp(1.75rem, 3vw, 2.5rem);
      --heading-sub: clamp(1.25rem, 2vw, 1.5rem);

      /* Line heights */
      --leading-tight: 1.25;
      --leading-snug: 1.375;
      --leading-normal: 1.5;
      --leading-relaxed: 1.7;

      /* Letter spacing */
      --tracking-tight: -0.01em;
      --tracking-normal: 0;
      --tracking-wide: 0.025em;
      --tracking-wider: 0.05em;
      --tracking-widest: 0.1em;

      /* Spacing - 8px base */
      --space-0: 0;
      --space-1: 0.25rem;
      --space-2: 0.5rem;
      --space-3: 0.75rem;
      --space-4: 1rem;
      --space-6: 1.5rem;
      --space-8: 2rem;
      --space-12: 3rem;
      --space-16: 4rem;
      --space-20: 5rem;
      --space-24: 6rem;
      --space-32: 8rem;

      --section-gap: var(--space-24);
      --container-max: 1200px;
      --container-padding: var(--space-6);
      --card-padding: var(--space-8);
      --grid-gap: var(--space-8);

      /* Shadows */
      --shadow-sm: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
      --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.15);
      --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.2);
      --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.25);
      --shadow-brand: 0 0 20px rgba(196, 30, 30, 0.15);

      /* Radius */
      --radius-sm: 0.375rem;
      --radius-md: 0.5rem;
      --radius-lg: 0.75rem;
      --radius-xl: 1rem;
      --radius-2xl: 1.5rem;

      /* Transitions */
      --ease-default: cubic-bezier(0.4, 0, 0.2, 1);
      --duration-fast: 150ms;
      --duration-normal: 200ms;
      --duration-slow: 300ms;
    }

    @media (prefers-reduced-motion: reduce) {
      * {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background-color: var(--color-bg-primary);
      color: var(--color-text-primary);
      font-family: var(--font-body);
      font-size: var(--text-base);
      line-height: var(--leading-relaxed);
      -webkit-font-smoothing: antialiased;
    }

    .container {
      max-width: var(--container-max);
      margin: 0 auto;
      padding: 0 var(--container-padding);
    }

    h1 {
      font-family: var(--font-heading);
      font-size: var(--heading-hero);
      font-weight: 800;
      line-height: var(--leading-tight);
      letter-spacing: var(--tracking-tight);
    }

    h2 {
      font-family: var(--font-heading);
      font-size: var(--heading-section);
      font-weight: 700;
      line-height: var(--leading-snug);
      letter-spacing: var(--tracking-tight);
    }

    h3 {
      font-family: var(--font-heading);
      font-size: var(--heading-sub);
      font-weight: 700;
      line-height: var(--leading-snug);
    }

    .overline {
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: var(--tracking-widest);
      text-transform: uppercase;
      color: var(--color-brand-secondary);
      margin-bottom: var(--space-4);
      display: block;
    }

    .subheading {
      font-size: var(--text-lg);
      line-height: var(--leading-relaxed);
      color: var(--color-text-secondary);
      font-weight: 400;
      max-width: 600px;
    }

    a {
      color: var(--color-brand-secondary);
      text-decoration: none;
      transition: color var(--duration-normal) var(--ease-default);
    }

    a:hover {
      color: var(--color-brand-primary);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-2);
      padding: var(--space-4) var(--space-6);
      font-size: var(--text-base);
      font-weight: 600;
      border-radius: var(--radius-md);
      border: none;
      cursor: pointer;
      transition: all var(--duration-normal) var(--ease-default);
      font-family: var(--font-body);
      text-decoration: none;
    }

    .btn-primary {
      background-color: var(--color-brand-primary);
      color: #FFFFFF;
      box-shadow: var(--shadow-brand);
    }

    .btn-primary:hover {
      background-color: #A01818;
      transform: translateY(-2px);
      box-shadow: 0 0 30px rgba(196, 30, 30, 0.25);
    }

    .btn-secondary {
      background-color: transparent;
      color: var(--color-brand-secondary);
      border: 2px solid var(--color-brand-secondary);
    }

    .btn-secondary:hover {
      background-color: var(--color-brand-secondary);
      color: #111111;
      transform: translateY(-2px);
    }

    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background-color: rgba(10, 10, 11, 0.95);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--color-border-default);
      padding: var(--space-4) 0;
      transition: all var(--duration-normal) var(--ease-default);
    }

    .nav-container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: var(--container-max);
      margin: 0 auto;
      padding: 0 var(--container-padding);
    }

    .logo {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      font-weight: 700;
      font-size: var(--text-xl);
      font-family: var(--font-heading);
    }

    .logo img {
      height: 48px;
      width: auto;
      display: block;
    }

    .nav-cta {
      padding: var(--space-3) var(--space-6);
      background-color: var(--color-brand-primary);
      color: #FFFFFF;
      border-radius: var(--radius-md);
      font-weight: 600;
      transition: all var(--duration-normal) var(--ease-default);
      font-size: var(--text-sm);
    }

    .nav-cta:hover {
      background-color: #A01818;
      box-shadow: var(--shadow-brand);
      transform: translateY(-1px);
    }

    .hero {
      padding-top: 120px;
      padding-bottom: var(--space-32);
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 100% 50%, rgba(212, 160, 32, 0.05) 0%, transparent 50%);
      pointer-events: none;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1fr 1.1fr;
      gap: var(--space-20);
      align-items: center;
      position: relative;
      z-index: 1;
    }

    .hero-content h1 {
      margin-bottom: var(--space-4);
      background: linear-gradient(135deg, #F3F4F6 0%, var(--color-brand-secondary) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-content .subheading {
      margin-bottom: var(--space-8);
    }

    .hero-cta-group {
      display: flex;
      gap: var(--space-4);
      flex-wrap: wrap;
      margin-top: var(--space-8);
    }

    .hero-image {
      position: relative;
      border-radius: var(--radius-2xl);
      overflow: hidden;
      aspect-ratio: 4/5;
      background: linear-gradient(135deg, var(--color-brand-primary), var(--color-brand-secondary));
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: var(--shadow-xl);
    }

    .hero-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    @media (max-width: 1024px) {
      .hero-grid {
        grid-template-columns: 1fr;
        gap: var(--space-12);
      }

      .hero-image {
        max-width: 500px;
        margin: 0 auto;
      }
    }

    .proof-bar {
      background-color: var(--color-bg-secondary);
      padding: var(--space-8) 0;
      border-top: 1px solid var(--color-border-default);
      border-bottom: 1px solid var(--color-border-default);
      margin: var(--space-20) 0;
    }

    .proof-items {
      display: flex;
      justify-content: center;
      align-items: center;
      flex-wrap: wrap;
      gap: var(--space-6);
    }

    .proof-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-1);
    }

    .proof-item strong {
      color: var(--color-brand-secondary);
      font-weight: 700;
      font-size: var(--text-lg);
    }

    .proof-item span {
      font-size: var(--text-sm);
      color: var(--color-text-secondary);
    }

    .proof-divider {
      color: var(--color-border-default);
      opacity: 0.5;
    }

    .menu-section {
      padding: var(--section-gap) 0;
    }

    .section-header {
      text-align: center;
      margin-bottom: var(--space-20);
    }

    .section-header .overline {
      display: inline-block;
      text-align: center;
    }

    .section-header h2 {
      margin-bottom: var(--space-4);
    }

    .section-header p {
      font-size: var(--text-lg);
      color: var(--color-text-secondary);
      max-width: 600px;
      margin: 0 auto;
    }

    .menu-categories {
      display: grid;
      gap: var(--space-20);
    }

    .menu-category-title {
      font-family: var(--font-heading);
      font-size: var(--text-2xl);
      font-weight: 700;
      color: var(--color-brand-secondary);
      padding-bottom: var(--space-4);
      border-bottom: 2px solid var(--color-brand-primary);
      margin-bottom: var(--space-8);
    }

    .menu-items {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--space-8);
    }

    .menu-item {
      padding: var(--space-6);
      background-color: var(--color-bg-secondary);
      border: 1px solid var(--color-border-default);
      border-radius: var(--radius-lg);
      transition: all var(--duration-normal) var(--ease-default);
    }

    .menu-item:hover {
      border-color: var(--color-brand-primary);
      transform: translateY(-2px);
      box-shadow: 0 0 20px rgba(196, 30, 30, 0.1);
    }

    .menu-item-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: var(--space-2);
    }

    .menu-item-name {
      font-family: var(--font-heading);
      font-size: var(--text-lg);
      font-weight: 700;
      flex: 1;
    }

    .menu-item-price {
      color: var(--color-brand-secondary);
      font-weight: 700;
      font-size: var(--text-lg);
      white-space: nowrap;
      margin-left: var(--space-4);
    }

    .menu-item-desc {
      font-size: var(--text-sm);
      color: var(--color-text-secondary);
      line-height: var(--leading-normal);
    }

    .gallery-section {
      padding: var(--section-gap) 0;
      background-color: var(--color-bg-secondary);
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--grid-gap);
      margin-top: var(--space-16);
    }

    .gallery-item {
      position: relative;
      aspect-ratio: 1;
      border-radius: var(--radius-xl);
      overflow: hidden;
      background: linear-gradient(135deg, var(--color-brand-primary), var(--color-brand-secondary));
      box-shadow: var(--shadow-lg);
      transition: transform var(--duration-normal) var(--ease-default);
    }

    .gallery-item:hover {
      transform: scale(1.02);
    }

    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .reviews-section {
      padding: var(--section-gap) 0;
    }

    .review-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--grid-gap);
      margin-top: var(--space-16);
    }

    .review-card {
      padding: var(--card-padding);
      background-color: var(--color-bg-secondary);
      border-left: 3px solid var(--color-brand-primary);
      border-radius: var(--radius-lg);
      transition: all var(--duration-normal) var(--ease-default);
    }

    .review-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
    }

    .review-stars {
      display: flex;
      gap: var(--space-1);
      margin-bottom: var(--space-4);
    }

    .star {
      color: var(--color-brand-secondary);
      font-size: var(--text-lg);
    }

    .review-quote {
      font-size: var(--text-base);
      line-height: var(--leading-relaxed);
      color: var(--color-text-primary);
      font-style: italic;
      margin-bottom: var(--space-4);
    }

    .review-author {
      font-size: var(--text-sm);
      color: var(--color-text-secondary);
      font-weight: 500;
    }

    .brand-section {
      padding: var(--section-gap) 0;
      background: linear-gradient(135deg, rgba(196, 30, 30, 0.05) 0%, rgba(212, 160, 32, 0.05) 100%);
      border-top: 1px solid var(--color-border-default);
      border-bottom: 1px solid var(--color-border-default);
    }

    .brand-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: var(--grid-gap);
      margin-top: var(--space-16);
    }

    .brand-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: var(--space-8);
    }

    .brand-card-image {
      width: 100%;
      aspect-ratio: 2/3;
      border-radius: var(--radius-xl);
      overflow: hidden;
      margin-bottom: var(--space-6);
      background: linear-gradient(135deg, var(--color-brand-primary), var(--color-brand-secondary));
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: var(--shadow-lg);
    }

    .brand-card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .brand-card h3 {
      color: var(--color-brand-secondary);
      margin-bottom: var(--space-3);
    }

    .brand-card p {
      font-size: var(--text-sm);
      color: var(--color-text-secondary);
      line-height: var(--leading-relaxed);
    }

    .story-section {
      padding: var(--section-gap) 0;
    }

    .story-grid {
      display: grid;
      grid-template-columns: 1fr 1.1fr;
      gap: var(--space-20);
      align-items: center;
    }

    .story-content h2 {
      margin-bottom: var(--space-6);
    }

    .story-content p {
      margin-bottom: var(--space-6);
      line-height: var(--leading-relaxed);
      color: var(--color-text-secondary);
    }

    .story-image {
      aspect-ratio: 4/5;
      border-radius: var(--radius-xl);
      overflow: hidden;
      background: linear-gradient(135deg, var(--color-brand-primary), var(--color-brand-secondary));
      box-shadow: var(--shadow-xl);
    }

    .story-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    @media (max-width: 1024px) {
      .story-grid {
        grid-template-columns: 1fr;
      }

      .story-image {
        order: -1;
      }
    }

    .instagram-section {
      padding: var(--section-gap) 0;
      text-align: center;
    }

    .instagram-button {
      display: inline-flex;
      align-items: center;
      gap: var(--space-3);
      margin-top: var(--space-8);
      background-color: var(--color-brand-primary);
      color: white;
      padding: var(--space-4) var(--space-8);
      border-radius: var(--radius-md);
      font-weight: 600;
      transition: all var(--duration-normal) var(--ease-default);
      text-decoration: none;
    }

    .instagram-button:hover {
      background-color: #A01818;
      transform: translateY(-2px);
      box-shadow: var(--shadow-brand);
    }

    .delivery-section {
      padding: var(--space-20) 0;
      border-top: 1px solid var(--color-border-default);
      border-bottom: 1px solid var(--color-border-default);
    }

    .cta-block {
      background: linear-gradient(135deg, var(--color-brand-primary), #9B1515);
      padding: var(--space-24);
      border-radius: var(--radius-xl);
      text-align: center;
      margin: var(--section-gap) 0;
      box-shadow: var(--shadow-xl);
    }

    .cta-block h2 {
      color: #FFFFFF;
      margin-bottom: var(--space-6);
    }

    .cta-block p {
      color: rgba(255, 255, 255, 0.95);
      font-size: var(--text-lg);
      margin-bottom: var(--space-8);
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    .cta-block .btn {
      background-color: var(--color-brand-secondary);
      color: #111111;
      font-weight: 700;
    }

    .cta-block .btn:hover {
      background-color: #E8B92D;
      transform: translateY(-2px);
    }

    footer {
      background-color: var(--color-bg-secondary);
      border-top: 1px solid var(--color-border-default);
      padding: var(--space-20) 0 var(--space-8);
    }

    .footer-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: var(--space-12);
      margin-bottom: var(--space-16);
    }

    .footer-col h3 {
      font-size: var(--text-lg);
      margin-bottom: var(--space-4);
      color: var(--color-brand-secondary);
    }

    .footer-col p,
    .footer-col a {
      font-size: var(--text-sm);
      line-height: var(--leading-relaxed);
      color: var(--color-text-secondary);
      display: block;
      margin-bottom: var(--space-2);
    }

    .footer-col a {
      color: var(--color-brand-secondary);
      transition: color var(--duration-normal) var(--ease-default);
    }

    .footer-col a:hover {
      color: var(--color-brand-primary);
    }

    .footer-bottom {
      border-top: 1px solid var(--color-border-default);
      padding-top: var(--space-8);
      text-align: center;
      font-size: var(--text-xs);
      color: var(--color-text-tertiary);
    }

    .fade-in {
      opacity: 0;
      animation: fadeIn 0.6s ease-out forwards;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .slide-in {
      opacity: 0;
      animation: slideIn 0.8s ease-out forwards;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(-20px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }
  </style>
</head>
<body>
  <!-- Navigation -->
  <nav>
    <div class="nav-container">
      <div class="logo">
        <img src="/dwf-images/detroit-waffle-factory-logo-design-2-transparent.png" alt="Detroit Waffle Factory">
      </div>
      <a href="#order" class="nav-cta">Order Now</a>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-content slide-in">
          <span class="overline">Waffles Reimagined for Everyone</span>
          <h1>Stacked in Detroit</h1>
          <p class="subheading">We're serving Detroit pride on every plate. Street-named menu items, custom artwork, and the kind of comfort food that hits different when it's made with love and local pride.</p>
          <div class="hero-cta-group">
            <button class="btn btn-primary">Order Now</button>
            <button class="btn btn-secondary">View Menu</button>
          </div>
        </div>
        <div class="hero-image fade-in">
          <img src="/dwf-images/waffle,-chicken,-and-slushie-delight.png" alt="Signature waffle, chicken, and blue raspberry drink">
        </div>
      </div>
    </div>
  </section>

  <!-- Proof Bar -->
  <div class="proof-bar">
    <div class="container">
      <div class="proof-items">
        <div class="proof-item">
          <strong>4.9</strong>
          <span>Google Stars</span>
        </div>
        <span class="proof-divider">•</span>
        <div class="proof-item">
          <strong>8</strong>
          <span>5-Star Reviews</span>
        </div>
        <span class="proof-divider">•</span>
        <div class="proof-item">
          <strong>March 2026</strong>
          <span>Grand Opening</span>
        </div>
        <span class="proof-divider">•</span>
        <div class="proof-item">
          <strong>1,130+</strong>
          <span>Instagram Followers</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Menu Section -->
  <section class="menu-section">
    <div class="container">
      <div class="section-header">
        <span class="overline">Full Menu</span>
