# ============================================================
# Scoot for Fun — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ============================================================


# ─── Authorize.Net (Payment) ────────────────────────────────
# Server-side secrets — set in Vercel dashboard, never in NEXT_PUBLIC_*
# Get from https://account.authorize.net > Account > API Credentials & Keys
AUTHNET_API_LOGIN_ID=
AUTHNET_TRANSACTION_KEY=
AUTHNET_ENV=sandbox

# Client-side (safe to expose — Accept.js uses these only to tokenise card
# data in the browser; your Transaction Key is NEVER exposed to the client)
# Public Client Key is on the same API Credentials page
NEXT_PUBLIC_AUTHNET_API_LOGIN_ID=
NEXT_PUBLIC_AUTHNET_PUBLIC_CLIENT_KEY=
NEXT_PUBLIC_AUTHNET_ENV=sandbox


# ─── Vercel KV (Slot Availability Persistence) ──────────────
# Injected automatically when you link a KV store in the Vercel dashboard:
#   Storage > KV > Create Store > Connect to project
# For local dev copy values from: Vercel dashboard > KV store > .env.local tab
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=


# ─── Resend (Transactional Email) ───────────────────────────
# Sign up at https://resend.com, verify scootforfun.com as a sender domain,
# then create an API key. EMAIL_FROM must be on the verified domain.
RESEND_API_KEY=
EMAIL_FROM=noreply@scootforfun.com
EMAIL_OWNER=bookings@scootforfun.com


# ─── Google Calendar (P1 — separate branch, leave blank for now) ────────────
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REFRESH_TOKEN=
# GOOGLE_CALENDAR_ID=
