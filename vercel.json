{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_SITE_URL": "https://caliberwebstudio.com"
  },
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.caliberwebstudio.com" }],
      "destination": "https://caliberwebstudio.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/detroitdogsalon", "destination": "/dds-demo.html" }
  ]
}
